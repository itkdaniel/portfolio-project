#
# Environment variable template — copy to .env.development or .env.production
# NEVER commit real secrets to version control.
# =============================================================================

# ---- Database ---------------------------------------------------------------
# PostgreSQL connection string (Neon, Supabase, Railway, local Postgres, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/synaptiq

# ---- Session ----------------------------------------------------------------
# Random 64-char hex string — generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_64_char_random_hex

# ---- Clerk Authentication ---------------------------------------------------
# Obtain from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# ---- Clerk (frontend, Vite-exposed) ----------------------------------------
# Must be prefixed with VITE_ to be bundled into the browser build
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# ---- Object Storage ---------------------------------------------------------
# Replit-managed object storage bucket IDs
DEFAULT_OBJECT_STORAGE_BUCKET_ID=replace_me
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public

# ---- API Server -------------------------------------------------------------
# Port the Express server listens on (workflow sets this automatically)
PORT=5000

# ---- Frontend ---------------------------------------------------------------
# Base path for the Vite dev server (set by Replit workflow)
BASE_PATH=/
